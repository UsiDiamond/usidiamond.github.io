{
  "name": "usidiamond.github.io",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start-dev": "ng serve",
    "start": "node server.js",
    "buildDev": "ng build --watch --configuration development",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "deploy": "gh-pages -d build",
    "test": "ng test --watch false",
    "coverage": "ng test --no-watch --code-coverage --browsers=ChromeHeadlessCI",
    "e2e": "nightwatch  -r ./e2e/html-reporter.js nightwatch.conf.js -e chrome",
    "e2e:test": "./node_modules/.bin/nightwatch --env 'chrome' --config './nightwatch.conf.js'",
    "e2e:firefox": "nightwatch -r e2e/html-reporter.js -c nightwatch.conf.js -e firefox",
    "e2e:safari": "nightwatch -r e2e/html-reporter.js -c nightwatch.conf.js -e safari",
    "e2e:edge": "nightwatch  -r e2e/html-reporter.js nightwatch.conf.js -e edge",
    "e2e:chrome": "nightwatch  -r e2e/html-reporter.js nightwatch.conf.js -e chrome",
    "dockerBuild": "docker build -f Dockerfile -t usidiamond.github.io .",
    "dockerRun": "docker run  --env=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin --workdir=/ -p 8080:8080 --runtime=runc -d usidiamond.github.io:latest"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.3",
    "@angular/common": "^21.0.3",
    "@angular/compiler": "^21.0.3",
    "@angular/core": "^21.0.3",
    "@angular/platform-browser": "^21.0.3",
    "@angular/platform-browser-dynamic": "^21.0.3",
    "@angular/router": "^21.0.3",
    "bootstrap": "^5.3.8",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "rxjs": "^7.8.2",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/localize": "^21.0.3",
    "@cucumber/cucumber": "^12.3.0",
    "@nightwatch/angular": "^3.1.1",
    "@nightwatch/mobile-helper": "^2.0.0",
    "@nightwatch/schematics": "^1.2.1",
    "@swc/core": "^1.15.3",
    "@types/chai": "^5.2.3",
    "@types/cucumber": "^6.0.1",
    "@types/jasmine": "^5.1.13",
    "@types/mocha": "^10.0.10",
    "@types/nightwatch": "^2.3.32",
    "@types/node": "^24.10.1",
    "chai": "^6.2.1",
    "chokidar": "^4.0.3",
    "chromedriver": "^143.0.0",
    "cucumber": "^6.0.7",
    "cucumber-html-reporter": "^7.2.0",
    "cucumber-pretty": "^6.0.1",
    "fs": "^0.0.1-security",
    "geckodriver": "^6.1.0",
    "gh-pages": "^6.3.0",
    "handlebars": "^4.7.9",
    "jasmine-core": "^5.13.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "karma-junit-reporter": "^2.0.1",
    "karma-spec-reporter": "^0.0.36",
    "mocha": "^11.7.5",
    "nightwatch": "^3.12.3",
    "nightwatch-html-reporter": "^2.0.6",
    "nohup": "^0.1.0",
    "path": "^0.12.7",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "registry": "https://github.com/usidiamond/"
  }
}
