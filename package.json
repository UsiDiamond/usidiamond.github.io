{
  "name": "usidiamond.github.io",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start-dev": "ng serve",
    "start": "npx --yes http-server ./public/usidiamond.github.io/browser -p 8080 -c-1 --silent",
    "buildDev": "ng build --watch --configuration development",
    "build": "ng build --configuration production",
    "deploy": "gh-pages -d build",
    "test": "ng test --watch false",
    "coverage": "ng test --no-watch --code-coverage --browsers=ChromeHeadlessCI",
    "e2e:run": "./node_modules/.bin/nightwatch --env chrome --config ./nightwatch.conf.js",
    "e2e:run:firefox": "./node_modules/.bin/nightwatch --env firefox --config ./nightwatch.conf.js",
    "e2e:run:safari": "./node_modules/.bin/nightwatch --env safari --config ./nightwatch.conf.js",
    "e2e:run:edge": "./node_modules/.bin/nightwatch --env edge --config ./nightwatch.conf.js",
    "e2e": "start-server-and-test start http://localhost:8080 e2e:run",
    "e2e:firefox": "start-server-and-test start http://localhost:8080 e2e:run:firefox",
    "e2e:safari": "start-server-and-test start http://localhost:8080 e2e:run:safari",
    "e2e:edge": "start-server-and-test start http://localhost:8080 e2e:run:edge",
    "dockerBuild": "docker build -f Dockerfile -t usidiamond.github.io .",
    "dockerRun": "docker run  --env=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin --workdir=/ -p 8080:8080 --runtime=runc -d usidiamond.github.io:latest",
    "e2e:docker": "docker compose up -d --wait && npm run e2e:run; CODE=$?; docker compose down; exit $CODE"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/platform-browser-dynamic": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "bootstrap": "^5.3.8",
    "rxjs": "^7.8.2",
    "three": "^0.183.2",
    "vanta": "^0.5.24",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/localize": "^21.2.8",
    "@cucumber/cucumber": "^12.3.0",
    "@nightwatch/angular": "^3.1.1",
    "@nightwatch/mobile-helper": "^2.0.0",
    "@nightwatch/schematics": "^1.2.1",
    "@swc/core": "^1.15.3",
    "@types/chai": "^5.2.3",
    "@types/cucumber": "^7.0.3",
    "@types/jasmine": "^5.1.13",
    "@types/mocha": "^10.0.10",
    "@types/nightwatch": "^3.0.1",
    "@types/node": "^24.10.1",
    "@types/three": "^0.183.1",
    "chai": "^6.2.1",
    "chokidar": "^4.0.3",
    "cucumber": "^6.0.7",
    "cucumber-html-reporter": "^7.2.0",
    "cucumber-pretty": "^6.0.1",
    "geckodriver": "^6.1.0",
    "gh-pages": "^6.3.0",
    "handlebars": "^4.7.9",
    "jasmine-core": "^5.13.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "karma-junit-reporter": "^2.0.1",
    "karma-spec-reporter": "^0.0.36",
    "mocha": "^11.7.5",
    "nightwatch": "^3.14.0",
    "nightwatch-html-reporter": "^2.0.6",
    "prettier": "^3.8.3",
    "start-server-and-test": "^2.0.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "registry": "https://github.com/usidiamond/"
  }
}
